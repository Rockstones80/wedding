# Copy to .env.local (gitignored) and fill in.

# Code printed on the invitation cards — unlocks the Location section.
# Note: this is a static site, so the code ships in the JS bundle. It keeps
# casual visitors out; it is not real security.
VITE_INVITE_CODE=forever

# Where RSVP submissions are POSTed as JSON (Web3Forms, Formspree, Google
# Apps Script web app, …). Leave unset to log to the console during dev.
# VITE_RSVP_ENDPOINT=https://...
